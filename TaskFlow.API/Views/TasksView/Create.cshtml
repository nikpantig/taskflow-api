@model TaskFlow.API.DTOs.CreateTaskItemDto

<h2>Create Task</h2>

<form method="post" action="/TasksView/Create">
	<div>
		<label>Title</label>
		<input asp-for="Title" />
	</div>

	<div>
		<label>Description</label>
		<input asp-for="Description" />
	</div>

	<button type="submit">Save</button>
</form>